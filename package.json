{
  "name": "dev-wireless-debug-extension",
  "publisher": "bbvmlabs",
  "displayName": "Dev Wireless Debug",
  "description": "Wireless Android debugging using adb pair and connect",
  "version": "1.1.1",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BBvmlabs/adb-wireless-debugger.git"
  },
  "bugs": {
    "url": "https://github.com/BBvmlabs/adb-wireless-debugger/issues"
  },
  "homepage": "https://wireless-debugger.bbvmlabs.top",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onView:dev-adbDevices",
    "onView:dev-adbToolbar",
    "onCommand:dev.wirelessDebug.pair",
    "onCommand:dev.wirelessDebug.connect",
    "onCommand:dev.wirelessDebug.refreshDevices",
    "onCommand:dev.wirelessDebug.disconnect",
    "onCommand:dev.wirelessDebug.mirror",
    "onCommand:dev.wirelessDebug.logcat",
    "onCommand:dev.wirelessDebug.stopLogcat",
    "onCommand:dev.wirelessDebug.screenshot",
    "onCommand:dev.wirelessDebug.switchToWireless",
    "onCommand:dev.wirelessDebug.reboot"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "ADB Wireless Debug",
      "properties": {
        "dev.wirelessDebug.scrcpyPath": {
          "type": "string",
          "default": "scrcpy",
          "description": "Path to the scrcpy executable. Default is 'scrcpy' (must be in PATH)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dev-adb-wireless-view",
          "title": "ADB Wireless",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "dev-adb-wireless-view": [
        {
          "type": "webview",
          "id": "dev-adbToolbar",
          "name": "Dev-ADB Wireless"
        },
        {
          "id": "dev-adbDevices",
          "name": "Dev-Devices"
        }
      ]
    },
    "commands": [
      {
        "command": "dev.wirelessDebug.refreshDevices",
        "title": "Refresh Devices",
        "icon": "$(refresh)"
      },
      {
        "command": "dev.wirelessDebug.clearHistory",
        "title": "Clear History",
        "icon": "$(trash)"
      },
      {
        "command": "dev.wirelessDebug.deleteHistoryItem",
        "title": "Remove from History",
        "icon": "$(close)"
      },
      {
        "command": "dev.wirelessDebug.pair",
        "title": "Pair Device via Code"
      },
      {
        "command": "dev.wirelessDebug.connect",
        "title": "Connect to Device",
        "icon": "$(link)"
      },
      {
        "command": "dev.wirelessDebug.disconnect",
        "title": "Disconnect Device",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "dev.wirelessDebug.mirror",
        "title": "Screen Mirror (scrcpy)",
        "icon": "$(display)"
      },
      {
        "command": "dev.wirelessDebug.logcat",
        "title": "Open Logcat",
        "icon": "$(output)"
      },
      {
        "command": "dev.wirelessDebug.stopLogcat",
        "title": "Stop Logcat",
        "icon": "$(close)"
      },
      {
        "command": "dev.wirelessDebug.screenshot",
        "title": "Take Screenshot",
        "icon": "$(camera)"
      },
      {
        "command": "dev.wirelessDebug.switchToWireless",
        "title": "Switch to Wireless mode",
        "icon": "$(rss)"
      },
      {
        "command": "dev.wirelessDebug.autoConnect",
        "title": "Auto-Discover & Connect",
        "icon": "$(broadcast)"
      },
      {
        "command": "dev.wirelessDebug.liveView",
        "title": "Live View (Internal Mirror)",
        "icon": "$(vm-active)"
      },
      {
        "command": "dev.wirelessDebug.reboot",
        "title": "Reboot Device",
        "icon": "$(sync)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dev.wirelessDebug.refreshDevices",
          "when": "view == dev-adbDevices",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dev.wirelessDebug.connect",
          "when": "view == dev-adbDevices && viewItem == recentDevice",
          "group": "inline@1"
        },
        {
          "command": "dev.wirelessDebug.deleteHistoryItem",
          "when": "view == dev-adbDevices && viewItem == recentDevice",
          "group": "inline@2"
        },
        {
          "command": "dev.wirelessDebug.liveView",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "inline@1"
        },
        {
          "command": "dev.wirelessDebug.logcat",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "inline@2"
        },
        {
          "command": "dev.wirelessDebug.stopLogcat",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "inline@3"
        },
        {
          "command": "dev.wirelessDebug.disconnect",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "inline@4"
        },
        {
          "command": "dev.wirelessDebug.mirror",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "1_actions@1"
        },
        {
          "command": "dev.wirelessDebug.screenshot",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "1_actions@2"
        },
        {
          "command": "dev.wirelessDebug.switchToWireless",
          "when": "view == dev-adbDevices && viewItem == connectedDeviceUsb",
          "group": "2_mode"
        },
        {
          "command": "dev.wirelessDebug.reboot",
          "when": "view == dev-adbDevices && (viewItem == connectedDeviceUsb || viewItem == connectedDeviceWireless)",
          "group": "z_danger"
        }
      ]
    }
  },
  "scripts": {
    "package": "node ./scripts/set-flavor.js prod && npx vsce package"
  },
  "dependencies": {
    "jmuxer": "^2.1.0"
  }
}